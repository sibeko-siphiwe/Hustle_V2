@model RegisterViewModel
@{
    ViewData["Title"] = "Register"; 
}

<div style="" class="container py-4">
    <form asp-action="Register" method="post" enctype="multipart/form-data" class="pt-5">
        <div class="mb-2">
            <div class="text-center mb-4">
                <h2 class="display-5 m-0 marker">Create an account</h2>
                <p class="m-0 lead text-muted">Verified workers. Real reviews. Safe hiring. Register today.</p>
            </div>
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="row">
                <div class="col-md">
                    <div>
                        <label asp-for="FirstName"></label>
                        <input asp-for="FirstName" class="form-control" placeholder="Enter your first name">
                    </div>
                </div>
                <div class="col-md">
                    <div>
                        <label asp-for="LastName"></label>
                        <input asp-for="LastName" class="form-control" placeholder="Enter your last name">
                    </div>
                </div>
            </div>
        </div>
        <div class="mb-2">
            <label asp-for="ImageUrl"></label>
            <input class="form-control" asp-for="ImageUrl" />
            <span class="small text-muted fw-light">(Optional)</span>
        </div>
        <div class="mb-2">
            <div class="row">
                <div class="col-md">
                    <div>
                        <label asp-for="PhoneNumber"></label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Enter your phone number">
                    </div>
                </div>
                <div class="col-md">
                    <div>
                        <label asp-for="Location"></label>
                        <input asp-for="Location" class="form-control" placeholder="Enter your location">
                    </div>
                </div>
            </div>
        </div>
        <div class="mb-2">
            <label asp-for="Bio"></label>
            <textarea asp-for="Bio" class="form-control" placeholder="Tell us about yourself..." rows="3"></textarea>
        </div>
        <div class="mb-2">
            <label asp-for="EmailAddress"></label>
            <input asp-for="EmailAddress" class="form-control" placeholder="Enter your location">
        </div>
        <div class="mb-2">
            <div class="row">
                <div class="col-md">
                    <div>
                        <label asp-for="Password"></label>
                        <input asp-for="Password" class="form-control" placeholder="Enter your new password">
                    </div>
                </div>
                <div class="col-md">
                    <div>
                        <label asp-for="ConfirmPassword"></label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Enter your password">
                    </div>
                </div>
            </div>
        </div>
        <div class="form-check form-switch mb-2">
            <input asp-for="Role" class="form-check-input" />
            <label asp-for="Role"></label>
        </div>
        <button type="submit" class="btn btn-dark w-100 mb-2">Create Account</button>
        <p class="text-center">Already have an account? <a asp-action="Login" asp-controller="Account">Login</a></p>
    </form>
</div>