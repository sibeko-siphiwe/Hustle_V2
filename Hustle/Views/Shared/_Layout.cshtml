<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hustle</title>
    <script type="importmap"></script>
    <link rel="stylesheet" asp-href-include="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" asp-href-include="~/lib/font-awesome/css/all.css" />
    <link rel="stylesheet" asp-href-include="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" asp-href-include="~/Hustle.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet"> 
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Permanent+Marker&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light navigation" id="navigation">
            <div class="container">
                <a class="navbar-brand pacifico" asp-area="" asp-controller="Home" asp-action="Index">Let's Hustle</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse justify-content-center ms-5">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">How it works</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Find Work</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Hire Employees</a>
                        </li>
                    </ul>
                </div>
                <div class="d-none d-lg-block">
                    <ul class="navbar-nav gap-2">
                        <li class="nav-item">
                            <a asp-action="" asp-controller="" class="btn btn-dark">Register</a>
                        </li>
                        <li class="nav-item">
                            <a asp-action="" asp-controller="" class="btn btn-outline-dark">Login</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div> 
    <footer class="bg-light text-dark border-top">
        <div class="pt-5 pb-3 container">
            <div class="row g-4">

                <div class="col-md-4">
                    <h5 class="mb-3" style="font-family: 'Pacifico', cursive;">Let's Hustle</h5>
                    <p class="text-muted small">
                        Connecting local talent with opportunities. Find work or hire skilled professionals in your community.
                    </p>
                </div>

                <div class="col-md-2">
                    <h6 class="mb-3">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <a href="#" class="text-dark text-decoration-none small">How It Works</a>
                        </li>
                        <li class="mb-2">
                            <a href="#" class="text-dark text-decoration-none small">Browse Jobs</a>
                        </li>
                        <li class="mb-2">
                            <a href="#" class="text-dark text-decoration-none small">For Businesses</a>
                        </li>
                        <li class="mb-2">
                            <a href="#" class="text-dark text-decoration-none small">Privacy Policy</a>
                        </li>
                        <li class="mb-2">
                            <a href="#" class="text-dark text-decoration-none small">Terms of Service</a>
                        </li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h6 class="mb-3">Contact Us</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2 small">
                            <i class="fas fa-envelope me-2"></i>
                            support@letshustle.com
                        </li>
                        <li class="mb-2 small">
                            <i class="fas fa-phone me-2"></i>
                            +27 123 456 789
                        </li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h6 class="mb-3">Follow Us</h6>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-dark text-decoration-none">
                            <i class="fab fa-facebook fa-lg"></i>
                        </a>
                        <a href="#" class="text-dark text-decoration-none">
                            <i class="fab fa-twitter fa-lg"></i>
                        </a>
                        <a href="#" class="text-dark text-decoration-none">
                            <i class="fab fa-instagram fa-lg"></i>
                        </a>
                        <a href="#" class="text-dark text-decoration-none">
                            <i class="fab fa-linkedin fa-lg"></i>
                        </a>
                    </div>
                </div>
            </div>

            <hr class="my-4">

            <div class="small text-muted text-center">
                &copy; @DateTime.Now.Year Let's Hustle. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
